# Database
DATABASE_URL=postgresql+asyncpg://faceuser:secret@localhost:5432/facedb

# Redis
REDIS_URL=redis://localhost:6379/0

# User Service (untuk validasi user_id jika diperlukan)
USER_SERVICE_URL=http://user-service:8001

# Face Engine
FACE_MODEL=buffalo_l          # InsightFace model (CPU-optimized)
SIMILARITY_THRESHOLD=0.60     # Minimum cosine similarity
MIN_QUALITY_SCORE=0.50        # Tolak foto di bawah threshold ini

# Adaptive Routing — konservatif untuk shared server
# CPU threshold rendah (60%) agar tidak mengganggu service lain
CPU_THRESHOLD=60              # Persen CPU guest VM
QUEUE_THRESHOLD=20            # Jumlah job pending (1 worker × 4 concurrency × 5 buffer)

# App
APP_ENV=development
SECRET_KEY=your-secret-key-change-me
